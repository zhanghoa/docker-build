# 使用极致精简的 Bookworm Slim 基础镜像
FROM node:20-bookworm-slim

ENV NODE_ENV=production
ENV PLAYWRIGHT_SKIP_BROWSER_SANDBOX=1
# 【瘦身核心 1】强行禁止 Playwright 在 npm install 时偷偷下载近 1GB 的无用官方浏览器内核
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# 【瘦身核心 2】将更新、安装、清理压缩在同一个 RUN 指令中，避免产生层垃圾缓存
RUN apt-get update && apt-get install -y --no-install-recommends \
    xvfb \
    xauth \
    libgtk-3-0 \
    libnss3 \
    libx11-xcb1 \
    libasound2 \
    libdbus-glib-1-2 \
    libgbm1 \
    fonts-liberation \
    unzip \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/* /var/cache/*

WORKDIR /app

# 【瘦身核心 3】仅安装 Node.js 生产依赖，加入 --ignore-scripts 屏蔽官方崩溃钩子
COPY package*.json ./
RUN npm ci --omit=dev --ignore-scripts \
    && npm cache clean --force

# 通过 Buildkit 外部挂载解压内核，并注入所有前置补丁
ARG ARCH=aarch64
ARG CAMOUFOX_VERSION=1.0.0

RUN --mount=type=bind,source=dist,target=/dist \
    mkdir -p /root/.cache/camoufox \
    && (unzip -q /dist/camoufox-${ARCH}.zip -d /root/.cache/camoufox || true) \
    && chmod -R 755 /root/.cache/camoufox \
    # ✅【补丁 1】注入版本伪装通行证，骗过 Node.js 服务端的前置强检查机制
    && echo "{\"version\":\"${CAMOUFOX_VERSION}\",\"release\":\"${CAMOUFOX_VERSION}\"}" > /root/.cache/camoufox/version.json \
    # ✅【补丁 2】拦截器设计：狸猫换太子，清洗官方被 [object Promise] 毒化的环境变量
    && mv /root/.cache/camoufox/camoufox-bin /root/.cache/camoufox/camoufox-bin-real \
    && echo '#!/bin/sh' > /root/.cache/camoufox/camoufox-bin \
    && echo 'export DISPLAY=:99' >> /root/.cache/camoufox/camoufox-bin \
    && echo 'exec /root/.cache/camoufox/camoufox-bin-real "$@"' >> /root/.cache/camoufox/camoufox-bin \
    && chmod +x /root/.cache/camoufox/camoufox-bin

# 拷贝剩余的服务端源码
COPY . .

EXPOSE 9377

# ✅【启动修正】在底层建立纯净隔离的虚拟显示服务，杜绝上游代码的干扰
CMD ["sh", "-c", "Xvfb :99 -screen 0 1280x1024x24 -nolisten tcp & sleep 1 && npm start"]
